# =============================================================================
# Discord
# =============================================================================
DISCORD_TOKEN=your_discord_bot_token_here

# =============================================================================
# Model provider — pick ONE: ollama (default), anthropic, openai
# =============================================================================
MODEL_PROVIDER=ollama

# Optional: shared sampling temperature (default: 0.6)
# MODEL_TEMPERATURE=0.6

# --- Ollama (local, no API key) ---
# OLLAMA_HOST=http://localhost:11434          # docker uses http://host.docker.internal:11434
# OLLAMA_MODEL=qwen3:4b

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MAX_TOKENS=4000

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5-mini-2025-08-07
# OPENAI_MAX_TOKENS=16000

# =============================================================================
# nba-stats-mcp launch options (stdio) — defaults work out of the box
# =============================================================================
# NBA_MCP_COMMAND=nba-stats-mcp
# NBA_MCP_ARGS=
# NBA_MCP_USE_UVX=true

# =============================================================================
# Heartbeat / proactive features
# =============================================================================
# Channel where daily recaps, previews, and standings are posted
# (heartbeat is OFF until this is set)
# HEARTBEAT_CHANNEL_ID=
# Channel where game-day threads are created (defaults to HEARTBEAT_CHANNEL_ID)
# GAME_THREAD_CHANNEL_ID=
# Set to "false" to disable heartbeat (default: true)
# HEARTBEAT_ENABLED=true

# =============================================================================
# Alerts (optional) — Discord webhook for startup / error notifications
# =============================================================================
# ALERTS_WEBHOOK_URL=https://discord.com/api/webhooks/...
