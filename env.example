# Discord bot token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: Use OpenAI instead of Strands default (Bedrock)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# Some OpenAI models require max_completion_tokens instead of max_tokens.
# If you get a 400 complaining about unsupported max_tokens, set:
# OPENAI_TOKEN_PARAM=max_completion_tokens
#
# For example, `gpt-5-mini-2025-08-07` requires:
# OPENAI_TOKEN_PARAM=max_completion_tokens
OPENAI_TOKEN_PARAM=

# Output token budget (number). Do NOT put a number in OPENAI_TOKEN_PARAM.
OPENAI_MAX_TOKENS=1500

# Some OpenAI models only support the default temperature (= 1). If you get a 400 about
# unsupported temperature values, set:
#
# For example, `gpt-5-mini-2025-08-07` only supports temperature=1.
OPENAI_TEMPERATURE=1

# MCP server launch options for nba-stats-mcp (stdio)
# Default runs the installed console script: `nba-stats-mcp`
NBA_MCP_COMMAND=nba-stats-mcp
NBA_MCP_ARGS=

# Optional: run via uvx instead (requires `uv` installed)
# NBA_MCP_USE_UVX=true


