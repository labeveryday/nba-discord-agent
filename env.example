# Discord bot token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Ollama server address (set by docker-compose, override if needed)
# OLLAMA_HOST=http://host.docker.internal:11434

# Ollama model (default: qwen3:8b-q4_K_M)
# OLLAMA_MODEL=qwen3:8b-q4_K_M

# MCP server launch options for nba-stats-mcp (stdio)
# NBA_MCP_COMMAND=nba-stats-mcp
# NBA_MCP_ARGS=
# NBA_MCP_USE_UVX=true

# Heartbeat / proactive features
# Channel where daily recaps, previews, and standings are posted (required for heartbeat)
# HEARTBEAT_CHANNEL_ID=
# Channel where game-day threads are created (defaults to HEARTBEAT_CHANNEL_ID)
# GAME_THREAD_CHANNEL_ID=
# Set to "false" to disable heartbeat (default: true)
# HEARTBEAT_ENABLED=true
